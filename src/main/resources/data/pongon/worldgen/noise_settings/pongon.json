{
  "sea_level": 0,
  "disable_mob_generation": false,
  "aquifers_enabled": false,
  "ore_veins_enabled": false,
  "legacy_random_source": false,
  "default_block": {
    "Name": "pongon:crushed_magma"
  },
  "default_fluid": {
    "Name": "minecraft:lava",
    "Properties": { "level": "0" }
  },
  "noise": {
    "height": 512,
    "min_y": -80,
    "size_horizontal": 1,
    "size_vertical": 2
  },
  "noise_router": {
    "barrier":                {"type": "minecraft:constant", "argument": 0.0},
    "fluid_level_floodedness":{"type": "minecraft:constant", "argument": 0.0},
    "fluid_level_spread":     {"type": "minecraft:constant", "argument": 0.0},
    "lava":                   {"type": "minecraft:constant", "argument": 0.0},
    "temperature":            {"type": "minecraft:constant", "argument": 0.0},
    "vegetation":             {"type": "minecraft:constant", "argument": 0.0},
    "continents":             {"type": "minecraft:noise", "noise": "pongon:island", "xz_scale": 1.0, "y_scale": 0.0},
    "erosion":                {"type": "minecraft:constant", "argument": 0.0},
    "depth": {
      "type": "minecraft:y_clamped_gradient",
      "from_y": -80,
      "to_y": 210,
      "from_value": 2.0,
      "to_value": -2.0
    },
    "ridges": {"type": "minecraft:constant", "argument": 0.0},

    "initial_density_without_jaggedness": {
      "type": "minecraft:y_clamped_gradient",
      "from_y": 132,
      "to_y": 140,
      "from_value": 0.8,
      "to_value": -0.8
    },

    "final_density": {
      "type": "minecraft:max",
      "argument1": {
        "type": "minecraft:y_clamped_gradient",
        "from_y": 132,
        "to_y": 140,
        "from_value": 0.8,
        "to_value": -0.8
      },
      "argument2": {
        "type": "minecraft:add",
        "argument1": {
          "type": "minecraft:noise",
          "noise": "pongon:island",
          "xz_scale": 1.0,
          "y_scale": 0.0
        },
        "argument2": {
          "type": "minecraft:mul",
          "argument1": {"type": "minecraft:constant", "argument": -1.0},
          "argument2": {
            "type": "minecraft:clamp",
            "input": {
              "type": "minecraft:y_clamped_gradient",
              "from_y": 135,
              "to_y": 210,
              "from_value": 0.3,
              "to_value": 2.0
            },
            "min": 0.3,
            "max": 2.0
          }
        }
      }
    },

    "vein_ridged":    {"type": "minecraft:constant", "argument": 0.0},
    "vein_gap":       {"type": "minecraft:constant", "argument": 0.0},
    "vein_toggle":    {"type": "minecraft:constant", "argument": 0.0}
  },

  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:not",
          "invert": {
            "type": "minecraft:y_above",
            "anchor": {"absolute": -75},
            "surface_depth_multiplier": 0,
            "add_stone_depth": false
          }
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": {"Name": "pongon:rock_vapor"}
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:not",
          "invert": {
            "type": "minecraft:y_above",
            "anchor": {"absolute": -70},
            "surface_depth_multiplier": 0,
            "add_stone_depth": false
          }
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": {"Name": "minecraft:bedrock"}
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:biome",
          "biome_is": ["pongon:pongol_forest"]
        },
        "then_run": {
          "type": "minecraft:condition",
          "if_true": {
            "type": "minecraft:y_above",
            "anchor": {"absolute": 137},
            "surface_depth_multiplier": 0,
            "add_stone_depth": false
          },
          "then_run": {
            "type": "minecraft:condition",
            "if_true": {
              "type": "minecraft:stone_depth",
              "offset": 3,
              "secondary_depth_range": 0,
              "surface_type": "floor",
              "add_surface_depth": false
            },
            "then_run": {
              "type": "minecraft:block",
              "result_state": {"Name": "pongon:pongol_dirt"}
            }
          }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:not",
          "invert": {
            "type": "minecraft:y_above",
            "anchor": {"absolute": 137},
            "surface_depth_multiplier": 0,
            "add_stone_depth": false
          }
        },
        "then_run": {
          "type": "minecraft:condition",
          "if_true": {
            "type": "minecraft:stone_depth",
            "offset": 9,
            "secondary_depth_range": 0,
            "surface_type": "floor",
            "add_surface_depth": false
          },
          "then_run": {
            "type": "minecraft:block",
            "result_state": {"Name": "minecraft:magma_block"}
          }
        }
      }
    ]
  },

  "spawn_target": []
}
